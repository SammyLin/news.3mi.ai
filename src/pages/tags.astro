---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="標籤雲" description="所有標籤">
  <header class="collection-header">
    <p class="eyebrow">Topics</p>
    <h1>標籤雲</h1>
    <p>用主題快速回看文章，共 <span id="tag-count">...</span> 個標籤。</p>
  </header>

  <div id="tags-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
async function loadTags() {
  const container = document.getElementById('tags-content');
  const countEl = document.getElementById('tag-count');
  if (!container) return;

  try {
    // Fetch tags from API (we need to create a tags endpoint, or use articles to build tag list)
    const res = await fetch('/api/articles?limit=100');
    const { articles = [] } = await res.json();

    // Build tag map from articles
    const tagMap: Record<string, { name: string; count: number }> = {};
    for (const article of articles) {
      for (const tag of article.tags || []) {
        if (!tagMap[tag.slug]) {
          tagMap[tag.slug] = { name: tag.name, count: 0 };
        }
        tagMap[tag.slug].count++;
      }
    }

    const tags = Object.entries(tagMap)
      .sort((a, b) => b[1].count - a[1].count)
      .map(([slug, { name, count }]) => ({ slug, name, count }));

    if (countEl) countEl.textContent = String(tags.length);
    if (tags.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">還沒有標籤。</div>';
      return;
    }

    container.innerHTML = `
      <div class="topic-cloud">
        ${tags.map(tag => `
          <a href="/tag/${tag.slug}">
            #${tag.name} <span>${tag.count}</span>
          </a>
        `).join('')}
      </div>`;
  } catch (err) {
    console.error('Failed to load tags:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

loadTags();
</script>
