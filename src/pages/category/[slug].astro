---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB } from '../../lib/db';

export async function getStaticPaths() {
  // Build-time: hardcode known slugs (since D1 binding isn't available)
  // When new categories are added, update this list and redeploy
  return [
    { params: { slug: 'ai' } },
    { params: { slug: 'architecture' } },
    { params: { slug: 'tools' } },
    { params: { slug: 'tutorial' } },
    { params: { slug: 'security' } },
    { params: { slug: 'life' } },
  ];
}

const { slug } = Astro.params;
---

<BaseLayout title="分類" description="">
  <header class="collection-header">
    <p class="eyebrow">Channel</p>
    <h1 id="category-title">分類</h1>
    <p id="category-description"></p>
  </header>

  <div id="articles-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>

  <script is:inline define:vars={{ slug }}>
    window.__CATEGORY_SLUG__ = slug;
  </script>
</BaseLayout>

<script>
async function loadCategory() {
  const slug = window.__CATEGORY_SLUG__;
  const titleEl = document.getElementById('category-title');
  const descEl = document.getElementById('category-description');
  const container = document.getElementById('articles-container');
  if (!container) return;

  try {
    const [categoriesRes, articlesRes] = await Promise.all([
      fetch('/api/categories'),
      fetch('/api/articles'),
    ]);

    const { categories = [] } = await categoriesRes.json();
    const { articles = [] } = await articlesRes.json();

    const category = categories.find((c) => c.slug === slug);
    const filteredArticles = articles.filter((a) => a.category?.slug === slug);

    if (category) {
      document.title = `${category.name} — news.3mi.ai`;
      if (titleEl) titleEl.textContent = `${category.name}`;
      if (descEl) descEl.textContent = category.description || '';
    } else {
      if (titleEl) titleEl.textContent = '找不到分類';
    }

    if (filteredArticles.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">這個分類還沒有文章。</div>';
      return;
    }

    container.innerHTML = `<div class="collection-list">` + filteredArticles.map((article) => `
      <a href="/post/${article.slug}" class="collection-card">
        <div class="collection-card-meta">
          ${article.category ? `<span style="color: ${article.category.color};">${escapeHtml(article.category.name)}</span>` : ''}
          <time>${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}</time>
          <span>${article.reading_time || 1} 分鐘</span>
        </div>
        <h3>${escapeHtml(article.title)}</h3>
        <p>${escapeHtml(article.excerpt || '')}</p>
      </a>
    `).join('') + `</div>`;
  } catch (err) {
    console.error('Failed to load category:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadCategory();
</script>
