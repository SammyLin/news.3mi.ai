---
const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: '首頁' },
  { href: '/category/ai', label: 'AI' },
  { href: '/archive', label: '前沿' },
  { href: '/tags', label: '專題' },
  { href: '/category/architecture', label: '架構' },
  { href: '/category/tutorial', label: '實戰' },
  { href: '/category/security', label: '安全' },
  { href: '/category/life', label: '生活' },
  { href: '/category/tools', label: '工具' },
  { href: '/archive', label: '存檔' },
  { href: '/about', label: '關於' },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">
      <span class="logo-mark">&gt; 3mi _</span>
      <span class="logo-title">port:3MI AI Signal</span>
      <span class="tag">AI 重度工程筆記</span>
    </a>
    <nav class="site-nav">
      {nav.map((item) => (
        <a href={item.href} class={pathname === item.href || pathname.startsWith(`${item.href}/`) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
